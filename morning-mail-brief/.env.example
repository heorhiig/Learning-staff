# Gmail OAuth — place credentials.json from Google Cloud Console in ./credentials/
GMAIL_CREDENTIALS_PATH=credentials/credentials.json
GMAIL_TOKEN_PATH=credentials/token.json

# Telegram — create bot via @BotFather, get chat id by messaging bot then visiting:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional AI polish (uses rules-only summary if unset)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Delivery window (local time). Script runs at RUN_HOUR then waits 0–WINDOW_MINUTES.
RUN_HOUR=8
WINDOW_MINUTES=120

# Comma-separated Gmail query fragments to always include (optional)
PRIORITY_SENDERS=
